# ============================================
# Oratioo CX Local — Variables de entorno
# Copiar a .env y llenar con valores reales
# ============================================

# ── PostgreSQL ──────────────────────────────────
DATABASE_URL=postgresql://postgres:Pangea.2026@localhost:5432/oratioo_cx
POSTGREST_URL=http://localhost:3001

# ── Pangea Orange (OBLIGATORIO) ─────────────────
ORANGE_USER=tu_usuario_pangea
ORANGE_PASS=tu_password_pangea

# ── Bot ──────────────────────────────────────────
MAQUINA_NOMBRE=PC-Espana
MAX_DNIS_POR_WORKER=0
REINTENTOS_DNI=3

# ── Proxies (opcional, uno por worker) ──────────
# PROXY_SERVER=http://ip:puerto
# PROXY_USER=usuario
# PROXY_PASS=password

# ── Web (Vite) ───────────────────────────────────
VITE_POSTGREST_URL=http://localhost:3001
VITE_JWT_SECRET=oratioo-local-jwt-secret-change-in-production-2024

# ── Bot API Key ──────────────────────────────────
BOT_API_KEY=oratioo-bot-internal-key
